{# Site-wide header. Included by every page. #}
<header class="site-header">

	{# Hamburger toggle - only visible on narrow screens via CSS. #}
	<button class="header-hamburger" type="button">
		<span class="header-hamburger-bar"></span>
		<span class="header-hamburger-bar"></span>
		<span class="header-hamburger-bar"></span>
	</button>

	<a class="header-home" href="/">
		<span class="header-logo">
			<svg class="header-logo-glyph" viewBox="0 0 1645 1618"><use href="#svg-omega"/></svg>
			<svg class="header-logo-aura" viewBox="0 0 1645 1618"><use href="#svg-omega"/></svg>
		</span>
		<span class="header-sitename">Infinite&nbsp;Chess</span>
	</a>

	<nav class="header-nav">
		<div class="header-nav-item header-dropdown-parent">
			<button class="header-nav-link" type="button">{{ t.nav.learn }}</button>
			<div class="header-dropdown" role="menu">
				<a class="header-dropdown-item" role="menuitem" href="/tutorial">{{ t.nav.learn_dropdown.tutorial }}</a>
				<a class="header-dropdown-item" role="menuitem" href="/checkmatepractice">{{ t.nav.learn_dropdown.checkmate_practice }}</a>
			</div>
		</div>

		<div class="header-nav-item header-dropdown-parent">
			<button class="header-nav-link" type="button">{{ t.nav.tools }}</button>
			<div class="header-dropdown" role="menu">
				<a class="header-dropdown-item" role="menuitem" href="/analysis">{{ t.nav.tools_dropdown.analysis_board }}</a>
				<a class="header-dropdown-item" role="menuitem" href="/editor">{{ t.nav.tools_dropdown.board_editor }}</a>
			</div>
		</div>

		<div class="header-nav-item">
			<a class="header-nav-link" href="/leaderboard">{{ t.nav.leaderboard }}</a>
		</div>

		<div class="header-nav-item">
			<a class="header-nav-link" href="/news">{{ t.nav.news }}</a>
		</div>

		<div class="header-nav-item">
			<a class="header-nav-link header-donate" href="/patron">{{ t.nav.donate }}</a>
		</div>
	</nav>

	<div class="header-actions">
		{% if memberInfo and memberInfo.signedIn %}
			<a id="login-link" class="header-icon-btn tooltip-d" href="/member/{{ memberInfo.username }}" data-tooltip="{{ t.actions.profile }}">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 2000 2000">
					<path d="M1656 1800H344c-70 0-123-70-96-134C370 1370 662 1200 1000 1200s629 170 752 466c27 64-25 134-96 134M592 600c0-220 183-400 408-400s408 180 408 400-183 400-408 400a405 405 0 01-408-400m1404 1164a952 952 0 00-612-697 593 593 0 00 220-560 610 610 0 00-530-503A608 608 0 00 388 600c0 190 89 357 228 467a952 952 0 00-612 697c-27 122 74 236 200 236h1590c128 0 229-114 200-236" fill="currentColor" fill-rule="evenodd" />
				</svg>
			</a>
			<a id="register-link" class="header-icon-btn tooltip-d" href="/logout" data-tooltip="{{ t.actions.logout }}">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 240 240">
					<path d="m160 170 50-50m0 0-50-50m50 50H90m30 50-.1 5.7a30 30 0 01-24 26.9l-5.7.7-10.2 1.1c-15.4 1.8-23 2.6-29.1.7a30 30 0 01-18.3-16.4C30 183 30 175.2 30 159.7V80.3c0-15.5 0-23.2 2.6-29A30 30 0 01 51 34.9c6-2 13.7-1 29 .7l10.3 1 5.7.8A30 30 0 01 120 64.3V70" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="20" />
				</svg>
			</a>
		{% else %}
			<a id="login-link" class="header-icon-btn tooltip-d" href="/login" data-tooltip="{{ t.actions.login }}">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 240 240">
					<path d="M150 165V190a20 20 0 01-20 20H60a20 20 0 01-20-20V50c0-11 9-20 20-20h70a20 20 0 01 20 20v30m50 40H90m0 0 25 25M90 120l25-25" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="20" />
				</svg>
			</a>
			<a id="register-link" class="header-icon-btn header-icon-btn-tight tooltip-d" href="/register" data-tooltip="{{ t.actions.register }}">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 3100 3100">
