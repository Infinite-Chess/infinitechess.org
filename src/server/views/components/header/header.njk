					<span class="arrow-head-right"></span>
				</div>
				<div id="perspective-settings-dropdown-item" class="settings-dropdown-item hidden">
					<p class="text">{{ t.settings.perspective }}</p>
					<span class="arrow-head-right"></span>
				</div>
				<div id="sound-settings-dropdown-item" class="settings-dropdown-item">
					<p class="text">{{ t.settings.sound }}</p>
					<span class="arrow-head-right"></span>
				</div>
				<div class="ping-meter hidden">
					<div>
						<span class="ping">{{ t.ping.label }}:</span>
						<strong class="ping-value">-</strong>
						<span class="ms">{{ t.ping.unit }}</span>
					</div>
					<div class="ping-bars">
						<div class="ping-bar"></div>
						<div class="ping-bar"></div>
						<div class="ping-bar"></div>
						<div class="ping-bar"></div>
						<div class="ping-glow"></div>
					</div>
					<svg class="svg-pawn spinny-pawn hidden"><use href="#svg-pawn"></use></svg>
				</div>
			</div>

			{# Language #}
			<div class="language-dropdown dropdown hidden">
				{{ sub_dropdown_title(t.settings.language) }}
				<div class="dropdown-scrollable">
					<div class="language-dropdown-item selected" value="en-US">
						<div class="language-names">
							<p class="name">English</p>
							<p class="englishName">English</p>
						</div>
						<span class="checkmark">✓</span>
					</div>
				</div>
			</div>

			{# Appearance #}
			<div class="appearance-dropdown dropdown hidden">
				{{ sub_dropdown_title(t.settings.appearance) }}
				<div class="dropdown-scrollable">
					<div class="select-option ui-theme" data-theme-toggle>
						<p class="text">{{ t.settings.appearance_dropdown.theme }}</p>
						<span class="select-value"></span>
					</div>
					<div class="select-option" data-legal-move-toggle>
						<p class="text">{{ t.settings.appearance_dropdown.legal_moves }}</p>
						<span class="select-value"></span>
					</div>
					{{ boolean_option("coordinates", t.settings.appearance_dropdown.coordinates) }}
					{{ boolean_option("starfield", t.settings.appearance_dropdown.starfield) }}
					{{ boolean_option("advanced-effects", t.settings.appearance_dropdown.advanced_effects) }}
					<p class="theme-title">{{ t.settings.appearance_dropdown.board_tiles }}</p>
					<div class="board-color-list"></div>
				</div>
			</div>

			{# Gameplay #}
			<div class="gameplay-dropdown dropdown hidden">
				{{ sub_dropdown_title(t.settings.gameplay) }}
				{{ boolean_option("drag", t.settings.gameplay_dropdown.drag) }}
				{{ boolean_option("premove", t.settings.gameplay_dropdown.premove) }}
				{{ boolean_option("animations", t.settings.gameplay_dropdown.animations) }}
				{{ boolean_option("fast-transitions", t.settings.gameplay_dropdown.fast_transitions) }}
				{{ boolean_option("lingering-annotations", t.settings.gameplay_dropdown.lingering_annotations) }}
			</div>

			{# Perspective #}
			<div class="perspective-dropdown dropdown hidden">
				{{ sub_dropdown_title(t.settings.perspective) }}
				<div class="perspective-options">
					<div class="perspective-option mouse-sensitivity">
						<div class="perspective-option-title">
							<p>{{ t.settings.perspective_dropdown.mouse_sensitivity }}</p>
						</div>
						<div class="slider-container">
							<input class="slider" type="range" min="25" max="200" value="100">
							<span class="value"></span>
						</div>
					</div>
					<div class="perspective-option fov">
						<div class="perspective-option-title">
							<p>{{ t.settings.perspective_dropdown.field_of_view }}</p>
						</div>
						<div class="slider-container">
							<input class="slider" type="range" min="60" max="150" value="90">
							<span class="value"></span>
						</div>
						<div class="reset-default-container hidden">
							<div class="reset-default">
								<svg class="svg-undo"><use href="#svg-undo"></use></svg>
								<span>{{ t.settings.perspective_dropdown.reset }}</span>
							</div>
						</div>
					</div>
				</div>
			</div>

			{# Sound #}
			<div class="sound-dropdown dropdown hidden">
				{{ sub_dropdown_title(t.settings.sound) }}
				<div class="sound-options">
					<div class="sound-option master-volume">
						<div class="sound-option-title">
							<p>{{ t.settings.sound_dropdown.master_volume }}</p>
						</div>
						<div class="slider-container">
							<input class="slider" type="range" min="0" max="100" value="100">
							<span class="value"></span>
						</div>
					</div>
					{{ boolean_option("ambience", t.settings.sound_dropdown.ambience) }}
				</div>
			</div>
		</div>
	</div>
</header>

{# Slide-in mobile menu (visible only at narrow widths). #}
