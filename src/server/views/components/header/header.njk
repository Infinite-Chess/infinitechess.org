{# Reusable boolean toggle row. #}
{% macro boolean_option(cls, label) -%}
<label class="boolean-option {{ cls }}">
	<p class="text">{{ label }}</p>
	<div class="switch">
		<input type="checkbox">
		<span></span>
	</div>
</label>
{%- endmacro %}

{# Settings sub-panel back-button/title bar. #}
{% macro sub_dropdown_title(title) -%}
<div class="dropdown-title">
	<span class="arrow-head-left"></span>
	<p class="text">{{ title }}</p>
</div>
{%- endmacro %}

{# Load header translations. #}
{% set t = templateT('header') %}

