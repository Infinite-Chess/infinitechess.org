{% extends "layout.njk" %}

{% set t = templateT('login') %}
{% set pageName = t.title %}

{% block style %}
<link rel="stylesheet" href="{{ manifest['css/login.css'] }}" />
{% endblock %}

{% block head %}
{# Ship the login component's [script] strings to the browser, preserving the existing window.t from layout.njk. #}
<script>window.t = Object.assign(window.t || {}, { login: {{ scriptT('login') | json | safe }} });</script>
{% endblock %}

{% block body %}
{% include "components/header/header.njk" %}

<main class="bg-checkerboard">
	{# Semi-opaque dark overlay sits above the checkerboard background, below all page content #}
	<div id="bg-overlay"></div>

	<form class="auth-card" id="login-form">
		<h1 class="auth-title">{{ t.title }}</h1>

		<div class="auth-field">
			<label for="username">{{ t.username_label }}</label>
			{# maxlength 320: the email max length from validateEmail() in validators.ts (larger than the 20-char username max). #}
			<input class="auth-input" type="text" id="username" name="username"
			       autocomplete="username" autocapitalize="off" maxlength="320" required />
		</div>

		<div class="auth-field">
			<label for="password">{{ t.password_label }}</label>
			{# maxlength 72: the password max length from validatePassword() in validators.ts (bcrypt's 72-byte limit). #}
			<input class="auth-input" type="password" id="password" name="password"
			       autocomplete="current-password" maxlength="72" required />
		</div>

		<div class="login-options">
			<label class="login-checkbox">
				<input type="checkbox" id="keep-logged-in" />
				<span>{{ t.keep_logged_in }}</span>
			</label>
			<a class="auth-link" href="/resetpassword">{{ t.reset_password }}</a>
		</div>

		{# Populated by login.ts on a failed attempt. #}
		<p class="auth-error hidden" id="login-error"></p>

		<button class="btn-primary" type="submit" id="login-submit">{{ t.submit }}</button>

		<p class="auth-prompt">{{ t.register_prompt }} <a class="auth-link" href="/register">{{ t.register_link }}</a></p>
	</form>
</main>

{% include "components/footer/footer.njk" %}
{% endblock %}

{% block script %}
<script type="module" src="{{ manifest['scripts/esm/views/login.ts'] }}"></script>
{% endblock %}
