{% extends "layout.njk" %}

{# Shared error page for every HTTP error (404, 500, 429, …). The status code, title,
   and message are passed in per-request — see utility/renderContext.ts. #}

{% set pageName = code ~ " " ~ title %}

{% block bodyClass %}sticky-footer{% endblock %}

{# Error-page styles live in global.css (already cached site-wide) so this page
   renders fully styled even for a rate-limited visitor — see css/global.css. #}

{% block body %}
{% include "components/header/header.njk" %}

<main class="bg-checkerboard page-centered">
	{# Semi-opaque dark overlay sits above the checkerboard background #}
	<div id="bg-overlay"></div>

	<section class="error-content">
		<p class="error-code">{{ code }}</p>
		<h1 class="error-title">{{ title }}</h1>
		<p class="error-message">{{ message }}</p>
		<a class="btn-primary error-home" href="/">Back to home</a>
	</section>
</main>

{% include "components/footer/footer.njk" %}
{% endblock %}
