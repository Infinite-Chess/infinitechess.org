<!DOCTYPE html>
<html lang="{{ lang | default('en-US') }}" dir="{{ dir | default('ltr') }}" data-theme="dark">
<head>
    {# Reads the saved UI color scheme from localStorage and applies it before CSS loads,
       preventing a flash of the wrong theme on initial page paint.
       Falls back to the system theme on first visit, then "dark" if neither is available. #}
    <script>
        (function(){
            var t=localStorage.getItem('color-scheme') || ((window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) ? 'light' : 'dark');
            document.documentElement.setAttribute('data-theme',t)
        })()
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {# Title composition: a page sets `pageName` (e.g. {% set pageName = "Leaderboard" %})
    and the brand is appended here. The home page just gets the brand. #}
    <title>{% if pageName %}{{ pageName }} • Infinite Chess{% else %}Infinite Chess{% endif %}</title>

    <link rel="icon" href="/img/favicon/favicon-light.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/img/favicon/favicon-dark.png" media="(prefers-color-scheme: dark)" />

    {# Global stylesheet: CSS variables, font-face, and shared utility classes #}
    <link rel="stylesheet" href="{{ manifest['css/global.css'] }}" />

    {# Site-wide header stylesheet #}
    <link rel="stylesheet" href="{{ manifest['css/header.css'] }}" />

    {# Site-wide toast notification stylesheet #}
    <link rel="stylesheet" href="{{ manifest['css/toast.css'] }}" />

    {# Site-wide footer stylesheet #}
    <link rel="stylesheet" href="{{ manifest['css/footer.css'] }}" />

    {# Page-specific stylesheet #}
    {% block style %}{% endblock %}

    {# Script-facing translations for site-wide components, injected as a global `t` object.
       Page-specific components should extend it via `Object.assign(window.t, ...)` in their own head block. #}
    <script>window.t = { header: {{ scriptT('header') | json | safe }}, shared: {{ scriptT('shared') | json | safe }} };</script>

    {# Hashed URL for the downsampler audio worklet processor. #}
    <script>window.$downsamplerProcessorUrl = "{{ manifest['scripts/esm/audio/processors/downsampler/DownsamplerProcessor.ts'] }}";</script>

    {# Any extra head content (meta tags, preloads, etc.) #}
    {% block head %}{% endblock %}
</head>
<body class="{% block bodyClass %}{% endblock %}">

    {% block body %}{% endblock %}

    {# Site-wide toast notification. Runtime: scripts/esm/components/toast.ts #}
    {% include "components/toast/toast.njk" %}

    {# Site-wide header script #}
    <script type="module" src="{{ manifest['scripts/esm/components/header/header.ts'] }}"></script>

    {# Pre-load Classical variant loader - used very commonly #}
    <script type="module" src="{{ manifest['src/shared/chess/variants/variant_scripts/variants/var_classical.ts'] }}"></script>

    {# Page entry-point script #}
    {% block script %}{% endblock %}

</body>
</html>
