{% extends "layout.njk" %}

{% block title %}Infinite Chess{% endblock %}

{% block style %}
<link rel="stylesheet" href="{{ manifest['css/index.css'] }}" />
{% endblock %}

{% block body %}
{% include "components/header/header.njk" %}

<main class="bg-checkerboard">
	{# Semi-opaque dark overlay sits above the checkerboard background, below all page content #}
	<div id="bg-overlay"></div>
	<div class="main-inner">

		{# -- Lobby home: buttons + open challenges ------------------------------- #}
		<div class="lobby-home">
			<div class="lobby-actions">
				<button class="lobby-btn" id="btn-create-game">
					<svg class="btn-icon svg-globe"><use href="#svg-globe"></use></svg>
					Create online game
				</button>
				<button class="lobby-btn" id="btn-challenge-friend">
					<svg class="btn-icon"><use href="#svg-profile"></use></svg>
					Challenge a friend
				</button>
				<button class="lobby-btn" id="btn-play-ai">
					<svg class="btn-icon svg-engine"><use href="#svg-engine"></use></svg>
					Play against computer
				</button>
			</div>

			{# -- Open challenges (lobby) ----------------------------------------- #}
			<section class="lobby">
				<h2>Lobby</h2>
				<div class="lobby-wrap">
					{# Faint omega background - references symbol already defined in header.njk #}
					<svg class="bg-omega" viewBox="0 0 1645 1618"><use href="#svg-omega"/></svg>
					<table class="lobby-table">
						<thead>
							<tr>
								<th>Player</th>
								<th>Variant</th>
								<th>Time</th>
								<th>Mode</th>
							</tr>
						</thead>
						{# Open seeks are listed in here #}
						<tbody id="lobby-tbody">
							{# Example lobby row #}
							{# <tr class="invite-row" title="Accept invite">
								<td>
									<span class="username-embed">
										<a class="username" href="#">Naviary</a>
										<span class="elo">1854</span>
									</span>
								</td>
								<td>
									<div class="cell-flex">
										<svg class="cell-icon"><use href="#svg-pawn"></use></svg>
										Classical
									</div>
								</td>
								<td>
									<div class="cell-flex">
										<svg class="cell-icon"><use href="#svg-speed-rapid"></use></svg>
										10+4
									</div>
								</td>
								<td>Rated</td>
							</tr> #}
						</tbody>
					</table>
				</div>
			</section>
		</div>{# .lobby-home #}
	</div>{# .main-inner #}
</main>

{% include "components/footer/footer.njk" %}

{# ════════════════════════════════════════════════════════════════════════
   Game Options Modal - shared by all three lobby action buttons.
   Fields are shown/hidden by JS depending on which button was pressed:
     Create online game   → hides #row-side, shows #row-game-mode, hides #row-strength
     Challenge a friend  → shows #row-side, shows #row-game-mode, hides #row-strength
     Play against computer → shows #row-side, hides #row-game-mode, shows #row-strength
   ════════════════════════════════════════════════════════════════════════ #}
<div id="modal-overlay" class="modal-overlay hidden">
	<div class="modal" role="dialog">

		<div class="modal-header">
			<div class="modal-header-gap"></div>
			<h2 class="modal-title">Game options</h2>
			<button class="modal-close" id="modal-close" type="button">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
				     stroke-linecap="round">
					<line x1="18" y1="6" x2="6" y2="18"/>
					<line x1="6" y1="6" x2="18" y2="18"/>
				</svg>
			</button>
		</div>

		<div class="modal-body">

			{# ── Variant ─────────────────────────────────────────────────── #}
			<div class="form-row">
				<span class="form-label">Variant</span>
				<div class="option-group">
					<button class="option-btn active" data-type="preset" type="button">Preset variant</button>
					<button class="option-btn" data-type="custom" type="button">Custom (ICN)</button>
				</div>
				{# Preset variant selector - clicking opens the variant picker popup (TODO) #}
				<div id="variant-preset-section">
					<button class="variant-display-btn" id="variant-display" type="button"
					        title="Click to choose a variant (coming soon)">
						<span class="variant-icon">♾️</span>
						<span id="variant-name">Infinite Chess</span>
						<svg class="chevron-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
						     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="6 9 12 15 18 9"/>
						</svg>
					</button>
				</div>
				{# Custom ICN - shown when "Custom (ICN)" tab is active #}
				<div id="variant-custom-section" class="hidden">
					<div class="icn-input-row">
						<div class="icn-input-wrap">
							<textarea class="icn-input" id="icn-input"
							          placeholder="Paste ICN notation here…" rows="1"></textarea>
						</div>
						<div class="icn-buttons">
							<button class="icon-btn" id="btn-paste-icn" type="button" title="Paste from clipboard">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								     stroke-linecap="round" stroke-linejoin="round">
									<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
									<rect x="8" y="2" width="8" height="4" rx="1"/>
								</svg>
							</button>
							<button class="icon-btn" id="btn-edit-icn" type="button" title="Open in board editor">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								     stroke-linecap="round" stroke-linejoin="round">
									<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
									<path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
								</svg>
							</button>
						</div>
					</div>
				</div>
			</div>

			{# Time sliders - revealed when "Finite" is selected #}
			<div class="time-control hidden" id="time-control">
				<div class="time-sliders-grid">
					<div class="slider-header">
						<label class="slider-label" for="slider-minutes">Minutes per side</label>
						<span class="slider-value" id="minutes-display">10</span>
					</div>
					<div class="slider-separator">+</div>
					<div class="slider-header">
						<span class="slider-value" id="increment-display">4</span>
						<label class="slider-label" for="slider-increment">Increment in seconds</label>
					</div>
					<input type="range" class="slider" id="slider-minutes" min="0" max="25" value="9" step="1">
					<div></div>
					<input type="range" class="slider" id="slider-increment" min="0" max="26" value="4" step="1">
				</div>
				<div class="time-presets">
					<button class="preset-btn" data-minutes="1" data-increment="2" type="button">1+2</button>
					<button class="preset-btn" data-minutes="2" data-increment="2" type="button">2+2</button>
					<button class="preset-btn" data-minutes="3" data-increment="2" type="button">3+2</button>
					<button class="preset-btn" data-minutes="5" data-increment="2" type="button">5+2</button>
					<button class="preset-btn" data-minutes="8" data-increment="3" type="button">8+3</button>
					<button class="preset-btn active" data-minutes="10" data-increment="4" type="button">10+4</button>
					<button class="preset-btn" data-minutes="15" data-increment="5" type="button">15+5</button>
					<button class="preset-btn" data-minutes="20" data-increment="6" type="button">20+6</button>
				</div>
			</div>

			{# ── Game mode (hidden for "Play against computer") ──────────── #}
			<div class="form-row" id="row-game-mode">
				<span class="form-label">Game mode</span>
				<div class="option-group">
					<button class="option-btn active" data-mode="casual" type="button">Casual</button>
					<button class="option-btn" data-mode="rated" type="button">Rated</button>
				</div>
			</div>

			{# ── Side (hidden for "Create lobby game") ───────────────────── #}
			<div class="form-row hidden" id="row-side">
				<span class="form-label">Side</span>
				<div class="option-group option-group--icons">
					<button class="option-btn" data-side="white" type="button">
						<svg class="side-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 45 45"><g fill="none" fill-rule="evenodd" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"><path d="M22.5 11.63V6M20 8h5" stroke-linejoin="miter"/><path d="M22.5 25s4.5-7.5 3-10.5c0 0-1-2.5-3-2.5s-3 2.5-3 2.5c-1.5 3 3 10.5 3 10.5" fill="#fff" stroke-linecap="butt" stroke-linejoin="miter"/><path d="M12.5 37c5.5 3.5 14.5 3.5 20 0v-7s9-4.5 6-10.5c-4-6.5-13.5-3.5-16 4V27v-3.5c-2.5-7.5-12-10.5-16-4-3 6 6 10.5 6 10.5v7" fill="#fff"/><path d="M12.5 30c5.5-3 14.5-3 20 0m-20 3.5c5.5-3 14.5-3 20 0m-20 3.5c5.5-3 14.5-3 20 0"/></g></svg>
						White
					</button>
					<button class="option-btn active" data-side="random" type="button">
						<svg class="side-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 45 45"><g fill="none" fill-rule="evenodd" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"><path d="M22.5 11.63V6M20 8h5" stroke-linejoin="miter"/><path d="M22.5 25s4.5-7.5 3-10.5c0 0-1-2.5-3-2.5s-3 2.5-3 2.5c-1.5 3 3 10.5 3 10.5" fill="#fff" stroke-linecap="butt" stroke-linejoin="miter"/><path d="M12.5 37c5.5 3.5 14.5 3.5 20 0v-7s9-4.5 6-10.5c-4-6.5-13.5-3.5-16 4V27v-3.5c-2.5-7.5-12-10.5-16-4-3 6 6 10.5 6 10.5v7" fill="#fff"/><path d="M12.5 30c5.5-3 14.5-3 20 0m-20 3.5c5.5-3 14.5-3 20 0m-20 3.5c5.5-3 14.5-3 20 0"/></g></svg>
						Random
					</button>
					<button class="option-btn" data-side="black" type="button">
						<svg class="side-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 45 45"><g fill="none" fill-opacity="1" fill-rule="evenodd" stroke="#000" stroke-dasharray="none" stroke-linecap="round" stroke-linejoin="round" stroke-miterlimit="4" stroke-opacity="1" stroke-width="1.5"><path d="M22.5 11.63V6" fill="none" stroke="#000" stroke-linejoin="miter"/><path d="M22.5 25s4.5-7.5 3-10.5c0 0-1-2.5-3-2.5s-3 2.5-3 2.5c-1.5 3 3 10.5 3 10.5" fill="#000" fill-opacity="1" stroke-linecap="butt" stroke-linejoin="miter"/><path d="M12.5 37c5.5 3.5 14.5 3.5 20 0v-7s9-4.5 6-10.5c-4-6.5-13.5-3.5-16 4V27v-3.5c-2.5-7.5-12-10.5-16-4-3 6 6 10.5 6 10.5v7" fill="#000" stroke="#000"/><path d="M20 8h5" fill="none" stroke="#000" stroke-linejoin="miter"/><path d="M32 29.5s8.5-4 6.03-9.65C34.15 14 25 18 22.5 24.5v2.1-2.1C20 18 10.85 14 6.97 19.85 4.5 25.5 13 29.5 13 29.5" fill="none" stroke="#fff"/><path d="M12.5 30c5.5-3 14.5-3 20 0m-20 3.5c5.5-3 14.5-3 20 0m-20 3.5c5.5-3 14.5-3 20 0" fill="none" stroke="#fff"/></g></svg>
						Black
					</button>
				</div>
			</div>

			{# ── Strength (only for "Play against computer") ─────────────── #}
			<div class="form-row hidden" id="row-strength">
				<span class="form-label">Strength</span>
				<div class="option-group">
					<button class="option-btn" data-level="1" type="button">1</button>
					<button class="option-btn" data-level="2" type="button">2</button>
					<button class="option-btn" data-level="3" type="button">3</button>
					<button class="option-btn active" data-level="4" type="button">4</button>
					<button class="option-btn" data-level="5" type="button">5</button>
					<button class="option-btn" data-level="6" type="button">6</button>
					<button class="option-btn" data-level="7" type="button">7</button>
					<button class="option-btn" data-level="8" type="button">8</button>
				</div>
			</div>

		</div>{# .modal-body #}

		<div class="modal-footer">
			<button class="submit-btn" id="modal-submit" type="button">Create Game</button>
		</div>

	</div>{# .modal #}
</div>{# #modal-overlay #}

{% endblock %}

{% block script %}
<script type="module" src="{{ manifest['scripts/esm/views/index.ts'] }}"></script>
{% endblock %}
