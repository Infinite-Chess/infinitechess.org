{% extends "layout.njk" %}

{% block title %}Infinite Chess{% endblock %}

{% block style %}
<link rel="stylesheet" href="{{ manifest['css/index.css'] }}" />
{% endblock %}

{% block body %}

{# ── Macros ───────────────────────────────────────────────────────────────── #}
{% macro eyeIcon() %}<svg class="svg-eye preview"><use href="#svg-eye"></use></svg>{% endmacro %}

{% macro variantGroupItem(group, iconId, name, description) %}
<button class="variant-group-item" data-group="{{ group }}">
	<svg class="group-icon {{ iconId }}"><use href="#{{ iconId }}"/></svg>
	<span class="group-name">{{ name }}</span>
	<span class="group-desc">{{ description }}</span>
	<svg class="group-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
</button>
{% endmacro %}

{% macro variantListBack(iconId, name, description) %}
<button class="variant-list-back">
	<svg class="back-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
	<svg class="group-icon {{ iconId }}"><use href="#{{ iconId }}"/></svg>
	<span class="group-name">{{ name }}</span>
	<span class="group-desc">{{ description }}</span>
</button>
{% endmacro %}

{% include "components/header/header.njk" %}

<main class="bg-checkerboard">
	{# Semi-opaque dark overlay sits above the checkerboard background, below all page content #}
	<div id="bg-overlay"></div>
	<div class="main-inner">

		{# -- Lobby home: buttons + open challenges ------------------------------- #}
		<div class="lobby-home">
			<div class="lobby-actions">
				<button class="lobby-btn" id="btn-create-game">
					<svg class="btn-icon svg-globe"><use href="#svg-globe"></use></svg>
					Create online game
				</button>
				<button class="lobby-btn" id="btn-challenge-friend">
					<svg class="btn-icon"><use href="#svg-profile"></use></svg>
					Challenge a friend
				</button>
				<button class="lobby-btn" id="btn-play-ai">
					<svg class="btn-icon svg-engine"><use href="#svg-engine"></use></svg>
					Play against computer
				</button>
			</div>

			{# -- Open challenges (lobby) ----------------------------------------- #}
			<section class="lobby">
				<h2>Lobby</h2>
				<div class="lobby-wrap scrollbar-thin">
					{# Faint omega background - references symbol already defined in header.njk #}
					<div class="omega-anchor">
						<svg class="bg-omega" viewBox="0 0 1645 1618"><use href="#svg-omega"/></svg>
					</div>
					<div class="lobby-grid">
						<div class="lobby-header">
							<div>Player</div>
							<div>Variant</div>
							<div>Time</div>
							<div>Mode</div>
						</div>
						{# Open seeks are listed in here #}
						<div id="lobby-tbody">
							{# Example lobby row #}
							{# <div class="invite-row" title="Accept invite" data-seek-id="123">
								<div class="lobby-cell">
									<div class="cell-flex">
										<span class="username-embed">
											<span class="username">Naviary</span>
											<span class="elo">1854</span>
										</span>
										<div class="side-dot black" title="Invite owner chooses to be black"></div>
									</div>
								</div>
								<div class="lobby-cell">
									<div class="cell-flex">
										<svg class="cell-icon svg-pawn"><use href="#svg-pawn"></use></svg>
										Classical
									</div>
								</div>
								<div class="lobby-cell">
									<div class="cell-flex">
										<svg class="cell-icon svg-speed-rapid"><use href="#svg-speed-rapid"></use></svg>
										10+4
									</div>
								</div>
								<div class="lobby-cell">Rated</div>
							</div> #}
						</div>
					</div>
				</div>
			</section>
		</div>{# .lobby-home #}
	</div>{# .main-inner #}
</main>

{% include "components/footer/footer.njk" %}

{# ════════════════════════════════════════════════════════════════════════
   Game Options Modal
   ════════════════════════════════════════════════════════════════════════ #}
<div id="modal-overlay" class="modal-overlay hidden">
	<div class="modal scrollbar-thin" role="dialog">

		<div class="modal-header">
			<div class="modal-header-gap"></div>
			<h2 class="modal-title">Game options</h2>
			<button class="modal-close" id="modal-close">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
				     stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
			</button>
		</div>

		<div class="modal-body">

			{# ── Variant ─────────────────────────────────────────────────── #}
			<div class="modal-row">
				<span class="model-label">Variant</span>
				{# Variant selector #}
				<div class="variant-selector" id="variant-selector">
					<button class="variant-display" id="variant-display">
						<svg class="variant-group-icon" id="variant-group-icon"><use></use></svg>
						<span id="variant-name" class="variant-name"></span>
						<svg class="modifier-add tooltip-d" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" data-tooltip="Add a fun modifier"><line x1="12" y1="4" x2="12" y2="20"/><line x1="4" y1="12" x2="20" y2="12"/></svg>
						<svg class="svg-pencil tooltip-d" data-tooltip="Edit position and gamerules"><use href="#svg-pencil"></use></svg>
						{{ eyeIcon() }}
						<svg class="selector-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
					</button>
					<div class="variant-dropdown" id="variant-dropdown">
						{% for g in variantGroups %}
						{{ variantGroupItem(g.group, g.iconId, g.name, g.description) }}
						{% endfor %}
						{{ variantGroupItem("custom", "svg-wrench", "Custom", "Your own position, your own rules.") }}
					</div>
					{% for g in variantGroups %}
					<div class="variant-dropdown variant-list-panel" data-group="{{ g.group }}">
						{{ variantListBack(g.iconId, g.name, g.description) }}
						{% for v in g.variants %}
						<button class="variant-item" data-code="{{ v.code }}">
							<span class="variant-name">{{ v.name }}</span>
							{{ eyeIcon() }}
						</button>
						{% endfor %}
					</div>
					{% endfor %}
					<div class="variant-dropdown variant-list-panel" data-group="custom" id="variant-custom-panel">
						{{ variantListBack("svg-wrench", "Custom", "Your own position, your own rules.") }}
						<div id="variant-custom-content"></div>
					</div>
					<div class="variant-dropdown modifier-dropdown" id="modifier-dropdown">
						<button class="variant-group-item" data-modifier="slide-limit">
							<svg class="group-icon svg-slide-limit"><use href="#svg-slide-limit"></use></svg>
							<span class="group-name">Slide Limit</span>
							<span class="group-desc">All pieces have a maximum distance they can slide in one move.</span>
						</button>
					</div>
				</div>
				{# Custom ICN - revealed when "From ICN" is selected in the Custom group #}
				<div id="variant-custom-section" class="hidden">
					<div class="icn-input-wrap">
						<textarea class="icn-input" id="icn-input"
						          placeholder="Paste ICN text here" rows="1"></textarea>
					</div>
					<p class="icn-error-text" id="icn-error-text"></p>
				</div>
				{# Modifiers - revealed when at least one modifier is selected #}
				<div id="modifiers-section" class="hidden">
					<div class="modifiers-row">
						<span class="modifiers-label">Modifiers:</span>
						<div class="modifiers-list" id="modifiers-list"></div>
					</div>
					<div id="slide-limit-section" class="slide-limit-section hidden">
						<span class="slide-limit-name">Slide Limit</span>
						<input type="range" class="slider" id="slider-slide-limit" min="0" max="25" step="1">
						<span class="slider-value" id="slide-limit-display"></span>
					</div>
				</div>
			</div>

			{# ── Time control ─────────────────────────────────────────────── #}
			<div>
				<div class="modal-row">
					<span class="model-label">Time control</span>
					<div class="option-group">
						<button class="option-btn active" data-time="timed">Timed</button>
						<button class="option-btn" data-time="infinite">Infinite</button>
					</div>
				</div>

				{# Time sliders - revealed when "Finite" is selected #}
				<div class="collapsible" id="time-sliders">
					<div class="time-sliders">
						<div class="time-sliders-grid">
							<div class="slider-header">
								<label class="slider-label left" for="slider-minutes">Minutes per side</label>
								<span class="slider-value" id="minutes-display"></span>
							</div>
							<div class="slider-separator">+</div>
							<div class="slider-header">
								<span class="slider-value" id="increment-display"></span>
								<label class="slider-label right" for="slider-increment">Increment in seconds</label>
							</div>
							<input type="range" class="slider" id="slider-minutes" min="0" max="25" step="1">
							<div></div>
							<input type="range" class="slider" id="slider-increment" min="0" max="26" step="1">
						</div>
						<div class="time-presets">
							<button class="preset-btn" data-minutes="1" data-increment="2">1+2</button>
							<button class="preset-btn" data-minutes="2" data-increment="2">2+2</button>
							<button class="preset-btn" data-minutes="3" data-increment="2">3+2</button>
							<button class="preset-btn" data-minutes="5" data-increment="2">5+2</button>
							<button class="preset-btn active" data-minutes="8" data-increment="3">8+3</button>
							<button class="preset-btn" data-minutes="10" data-increment="4">10+4</button>
							<button class="preset-btn" data-minutes="15" data-increment="5">15+5</button>
							<button class="preset-btn" data-minutes="20" data-increment="6">20+6</button>
						</div>
					</div>
				</div>
			</div>

			{# ── Game mode (hidden for "Play against computer") ──────────── #}
			<div class="modal-row" id="row-game-mode">
				<span class="model-label">Game mode</span>
				<div class="option-group">
					<button class="option-btn active" data-mode="casual">Casual</button>
					<button class="option-btn" data-mode="rated">Rated</button>
				</div>
			</div>

			{# ── Side (hidden for "Create lobby game") ───────────────────── #}
			<div class="modal-row">
				<span class="model-label">Side</span>
				<div class="option-group icons">
					<button class="option-btn" data-side="white">
						<svg class="side-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 45 45"><g fill="none" fill-rule="evenodd" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"><path d="M22.5 11.63V6M20 8h5" stroke-linejoin="miter"/><path d="M22.5 25s4.5-7.5 3-10.5c0 0-1-2.5-3-2.5s-3 2.5-3 2.5c-1.5 3 3 10.5 3 10.5" fill="#fff" stroke-linecap="butt" stroke-linejoin="miter"/><path d="M12.5 37c5.5 3.5 14.5 3.5 20 0v-7s9-4.5 6-10.5c-4-6.5-13.5-3.5-16 4V27v-3.5c-2.5-7.5-12-10.5-16-4-3 6 6 10.5 6 10.5v7" fill="#fff"/><path d="M12.5 30c5.5-3 14.5-3 20 0m-20 3.5c5.5-3 14.5-3 20 0m-20 3.5c5.5-3 14.5-3 20 0"/></g></svg>
						White
					</button>
					<button class="option-btn active" data-side="random">
						<svg class="side-icon" xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 450 450"><defs><clipPath id="a"><path d="M0 0h225v450H0"/></clipPath><clipPath id="b"><path d="M225 0H450v450H225"/></clipPath></defs><g stroke-linejoin="round" stroke-width="15" clip-path="url(#a)"><g fill="#000" stroke="#000"><path d="M225 116.3V60M200 80h50" fill="none" stroke-linecap="round"/><path d="M225 250s45-75 30-105c0 0-10-25-30-25s-30 25-30 25c-15 30 30 105 30 105"/><path d="M115 370c55 35 155 35 210 0v-70s90-45 60-105c-40-65-135-35-160 40V270v-35c-35-75-130-105-160-40-30 60 50 100 50 100V370"/></g><g fill="none" stroke="#FFF" stroke-linecap="round"><path d="M225 200s32.5-30 20-55c0 0-5-15-20-15s-20 15-20 15c-12.5 25 20 55 20 55" stroke-linecap="square"/><path d="M320 295s85-40 60.3-96.5C341.5 140 250 180 225 245l.1 21-.1-21C200 180 99 140 70 198.5c-25 56.5 48.5 90 48.5 90"/><path d="M115 300c55-30 155-30 210 0m-210 35c55-30 155-30 210 0m-210 35c55-30 155-30 210 0"/></g></g><g stroke="#000" stroke-width="15" clip-path="url(#b)"><g fill="#FFF" stroke-linejoin="round"><path d="M225 116.3V60M200 80h50" fill="none" stroke-linecap="round"/><path d="M225 250s45-75 30-105c0 0-10-25-30-25s-30 25-30 25c-15 30 30 105 30 105"/><path d="M115 370c55 35 155 35 210 0v-70s90-45 60-105c-40-65-135-35-160 40V270v-35c-35-75-130-105-160-40-30 60 50 100 50 100V370"/></g><path d="M115 300c55-30 155-30 210 0m-210 35c55-30 155-30 210 0m-210 35c55-30 155-30 210 0" fill="none" stroke-linecap="round"/></g></svg>

						Random
					</button>
					<button class="option-btn" data-side="black">
						<svg class="side-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 45 45"><g fill="none" fill-opacity="1" fill-rule="evenodd" stroke="#000" stroke-dasharray="none" stroke-linecap="round" stroke-linejoin="round" stroke-miterlimit="4" stroke-opacity="1" stroke-width="1.5"><path d="M22.5 11.63V6" fill="none" stroke="#000" stroke-linejoin="miter"/><path d="M22.5 25s4.5-7.5 3-10.5c0 0-1-2.5-3-2.5s-3 2.5-3 2.5c-1.5 3 3 10.5 3 10.5" fill="#000" fill-opacity="1" stroke-linecap="butt" stroke-linejoin="miter"/><path d="M12.5 37c5.5 3.5 14.5 3.5 20 0v-7s9-4.5 6-10.5c-4-6.5-13.5-3.5-16 4V27v-3.5c-2.5-7.5-12-10.5-16-4-3 6 6 10.5 6 10.5v7" fill="#000" stroke="#000"/><path d="M20 8h5" fill="none" stroke="#000" stroke-linejoin="miter"/><path d="M32 29.5s8.5-4 6.03-9.65C34.15 14 25 18 22.5 24.5v2.1-2.1C20 18 10.85 14 6.97 19.85 4.5 25.5 13 29.5 13 29.5" fill="none" stroke="#fff"/><path d="M12.5 30c5.5-3 14.5-3 20 0m-20 3.5c5.5-3 14.5-3 20 0m-20 3.5c5.5-3 14.5-3 20 0" fill="none" stroke="#fff"/></g></svg>
						Black
					</button>
				</div>
			</div>

			{# ── Strength (only for "Play against computer") ─────────────── #}
			<div class="modal-row hidden" id="row-strength">
				<span class="model-label">Strength</span>
				<div class="option-group">
					<button class="option-btn" data-level="1">1</button>
					<button class="option-btn" data-level="2">2</button>
					<button class="option-btn" data-level="3">3</button>
					<button class="option-btn active" data-level="4">4</button>
					<button class="option-btn" data-level="5">5</button>
					<button class="option-btn" data-level="6">6</button>
					<button class="option-btn" data-level="7">7</button>
					<button class="option-btn" data-level="8">8</button>
				</div>
			</div>

		</div>{# .modal-body #}

		<div class="modal-footer">
			<button class="submit-btn" id="modal-submit">Create Game</button>
		</div>

	</div>{# .modal #}
</div>{# #modal-overlay #}

{% endblock %}

{% block script %}
<script type="module" src="{{ manifest['scripts/esm/views/index/index.ts'] }}"></script>
{% endblock %}
